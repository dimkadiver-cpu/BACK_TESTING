# Signal Chain Backtesting Lab — environment variables
# Copy to .env and fill in values

APP_ENV=dev
LOG_LEVEL=INFO

# Source DB (existing TeleSignalBot database)
DATABASE_URL=sqlite:///./data/source.sqlite3

# Results DB (simulation output)
RESULTS_DB_URL=sqlite:///./data/results.sqlite3

# Market data directory (OHLCV Parquet or CSV files)
MARKET_DATA_DIR=./data/market

# Default timezone for all timestamps
DEFAULT_TIMEZONE=UTC

# Artifacts output directory
ARTIFACTS_DIR=./artifacts

# --- Optional: Telegram acquisition ---
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_SESSION=signal_chain_lab
